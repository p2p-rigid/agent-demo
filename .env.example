# DeepSeek API Key (required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Model name (optional, defaults to deepseek/deepseek-chat)
MODEL_NAME=deepseek/deepseek-chat

# Log complete ADK LLM request/response payloads for prompt tuning.
# Warning: this can contain user data and model outputs.
LOG_LLM_IO=false
LLM_IO_LOG_PATH=logs/llm_io.jsonl
